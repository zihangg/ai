{
  "tasks": {
    "start": "deno run --allow-read --allow-write --allow-env src/cli.ts",
    "new": "deno run --allow-read --allow-write --allow-env src/cli.ts new",
    "sync": "deno run --allow-read --allow-write --allow-env src/cli.ts sync",
    "desync": "deno run --allow-read --allow-write --allow-env src/cli.ts desync",
    "list": "deno run --allow-read --allow-write --allow-env src/cli.ts list",
    "check": "deno check src/cli.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "@cliffy/prompt": "jsr:@cliffy/prompt@1.0.0-rc.8",
    "@std/yaml": "jsr:@std/yaml@^1.0.5",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/fs": "jsr:@std/fs@^1.0.6",
    "@std/cli": "jsr:@std/cli@^1.0.10"
  },
  "fmt": {
    "exclude": ["dist/", ".sync/"]
  }
}
